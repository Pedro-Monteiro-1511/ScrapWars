{
  "RabbitMq": {
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/"
  },
  "RabbitMqTopology": {
    "PriceCheckRequestedQueue": "scrapwars.scraper.price-check.requested",
    "PriceScrapedExchange": "scrapwars.events.product-price-scraped",
    "PriceScrapedRoutingKey": "product.price-scraped",
    "PriceScrapeFailedExchange": "scrapwars.events.product-price-scrape-failed",
    "PriceScrapeFailedRoutingKey": "product.price-scrape-failed"
  },
  "Scraping": {
    "RequestTimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
